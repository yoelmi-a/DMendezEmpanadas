@model IEnumerable<ResumenPedidoViewModel>
@{
    ViewData["Title"] = "Mis Pedidos";
}

<h2 class="mb-4"><i class="bi bi-clock-history me-2"></i>Mis Pedidos</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>Aún no has realizado ningún pedido.
        <a asp-controller="Catalogo" asp-action="Index" class="alert-link ms-1">¡Ordena ahora!</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Fecha</th>
                    <th>Ítems</th>
                    <th>Entrega</th>
                    <th>Estado</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>@p.Id</strong></td>
                        <td>@p.CreadoEn.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@p.CantidadItems</td>
                        <td>@(p.MetodoEntrega == MetodoEntrega.Recogida ? "Recogida" : "Domicilio")</td>
                        <td>
                            <span class="badge @BadgePorEstado(p.Estado)">@p.Estado</span>
                        </td>
                        <td class="text-end fw-bold">RD$ @p.Total.ToString("N2")</td>
                        <td>
                            <a asp-action="Detalle" asp-route-id="@p.Id"
                               class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    string BadgePorEstado(string estado) => estado switch
    {
        "Recibido"      => "bg-primary",
        "EnPreparacion" => "bg-warning text-dark",
        "EnCamino"      => "bg-info text-dark",
        "Entregado"     => "bg-success",
        "Cancelado"     => "bg-secondary",
        _               => "bg-light text-dark"
    };
}
