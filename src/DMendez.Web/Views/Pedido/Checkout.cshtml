@model CheckoutViewModel
@{
    ViewData["Title"] = "Confirmar pedido";
}

<h2 class="mb-4"><i class="bi bi-credit-card me-2"></i>Confirmar pedido</h2>

<div class="row g-4">
    {{-- Formulario de opciones --}}
    <div class="col-md-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-truck me-2"></i>Método de entrega
            </div>
            <div class="card-body">
                <form asp-action="Checkout" method="post" id="formCheckout">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" asp-for="MetodoEntrega"
                                   value="0" id="recogida" />
                            <label class="form-check-label" for="recogida">
                                <i class="bi bi-shop me-1"></i>Recogida en local
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="MetodoEntrega"
                                   value="1" id="domicilio" />
                            <label class="form-check-label" for="domicilio">
                                <i class="bi bi-house me-1"></i>Entrega a domicilio
                            </label>
                        </div>
                        <span asp-validation-for="MetodoEntrega" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CodigoPromocion" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-tag"></i></span>
                            <input asp-for="CodigoPromocion" class="form-control"
                                   placeholder="Código opcional" />
                        </div>
                        <span asp-validation-for="CodigoPromocion" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 p-3 bg-warning bg-opacity-10 rounded border border-warning">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" asp-for="SimularFalloPago" />
                            <label class="form-check-label" asp-for="SimularFalloPago">
                                <strong>Simular fallo de pago</strong>
                                <small class="text-muted d-block">Activa esta opción para probar el manejo de errores.</small>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-danger w-100 btn-lg">
                        <i class="bi bi-lock me-1"></i>Confirmar y pagar
                    </button>
                </form>
            </div>
        </div>
    </div>

    {{-- Resumen del pedido --}}
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-receipt me-2"></i>Resumen
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var item in Model.Carrito.Items)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@item.NombreProducto <span class="text-muted">× @item.Cantidad</span></span>
                            <span>RD$ @item.Subtotal.ToString("N2")</span>
                        </li>
                    }
                </ul>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between text-muted small mb-1">
                    <span>Subtotal</span><span>RD$ @Model.Carrito.Subtotal.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between text-muted small mb-1">
                    <span>ITBIS (18%)</span><span>RD$ @Model.Carrito.Impuestos.ToString("N2")</span>
                </div>
                @if (Model.Descuento > 0)
                {
                    <div class="d-flex justify-content-between text-success small mb-1">
                        <span>Descuento</span><span>- RD$ @Model.Descuento.ToString("N2")</span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span class="text-danger">RD$ @Model.TotalConDescuento.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
