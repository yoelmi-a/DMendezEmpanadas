@model DetallePedidoViewModel
@{
    ViewData["Title"] = $"Pedido #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-receipt me-2"></i>Pedido #@Model.Id</h2>
    <span class="badge fs-6 @BadgePorEstado(Model.Estado)">@Model.Estado</span>
</div>

<div class="row g-4">
    {{-- Ítems del pedido --}}
    <div class="col-md-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-bag me-2"></i>Productos
            </div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-end">Precio unit.</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.NombreProducto</td>
                                <td class="text-center">@item.Cantidad</td>
                                <td class="text-end">RD$ @item.PrecioUnitario.ToString("N2")</td>
                                <td class="text-end fw-bold">RD$ @item.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between text-muted small mb-1">
                    <span>Subtotal</span><span>RD$ @Model.Subtotal.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between text-muted small mb-1">
                    <span>ITBIS (18%)</span><span>RD$ @Model.Impuestos.ToString("N2")</span>
                </div>
                @if (Model.Descuento > 0)
                {
                    <div class="d-flex justify-content-between text-success small mb-1">
                        <span>Descuento (@Model.CodigoPromocion)</span>
                        <span>- RD$ @Model.Descuento.ToString("N2")</span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span class="text-danger">RD$ @Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>

        {{-- Información adicional --}}
        <div class="card shadow-sm">
            <div class="card-body">
                <p class="mb-1">
                    <strong><i class="bi bi-truck me-2"></i>Método de entrega:</strong>
                    @(Model.MetodoEntrega == MetodoEntrega.Recogida ? "Recogida en local" : "Entrega a domicilio")
                </p>
                <p class="mb-1">
                    <strong><i class="bi bi-calendar me-2"></i>Fecha del pedido:</strong>
                    @Model.CreadoEn.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </p>
                @if (!string.IsNullOrEmpty(Model.ReferenciaPago))
                {
                    <p class="mb-0">
                        <strong><i class="bi bi-shield-check me-2"></i>Ref. pago:</strong>
                        <code class="small">@Model.ReferenciaPago</code>
                    </p>
                }
            </div>
        </div>
    </div>

    {{-- Historial de estados --}}
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-clock-history me-2"></i>Historial de estados
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var h in Model.Historial)
                    {
                        <li class="list-group-item">
                            <span class="badge @BadgePorEstado(h.Estado) me-2">@h.Estado</span>
                            <small class="text-muted">@h.FechaHora.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            @if (!string.IsNullOrEmpty(h.Observacion))
                            {
                                <p class="mb-0 small text-muted mt-1">@h.Observacion</p>
                            }
                        </li>
                    }
                </ul>
            </div>
        </div>

        @if (Model.PuedeCancelarse)
        {
            <form asp-action="Cancelar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger w-100"
                        onclick="return confirm('¿Seguro que deseas cancelar este pedido?')">
                    <i class="bi bi-x-circle me-1"></i>Cancelar pedido
                </button>
            </form>
        }
    </div>
</div>

<div class="mt-4">
    <a asp-action="Historial" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver a mis pedidos
    </a>
</div>

@functions {
    string BadgePorEstado(string estado) => estado switch
    {
        "Recibido"      => "bg-primary",
        "EnPreparacion" => "bg-warning text-dark",
        "EnCamino"      => "bg-info text-dark",
        "Entregado"     => "bg-success",
        "Cancelado"     => "bg-secondary",
        _               => "bg-light text-dark"
    };
}
