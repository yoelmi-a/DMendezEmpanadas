@model IEnumerable<Producto>
@{
    ViewData["Title"] = "Gestión de Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-box me-2"></i>Productos</h2>
    <a asp-action="Crear" class="btn btn-danger">
        <i class="bi bi-plus-lg me-1"></i>Nuevo producto
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th class="text-end">Precio</th>
                <th class="text-center">Disponible</th>
                <th class="text-center">Combo</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr class="@(!p.EstaDisponible ? "text-muted" : "")">
                    <td>@p.Id</td>
                    <td>@p.Nombre</td>
                    <td><span class="badge bg-secondary">@p.Categoria</span></td>
                    <td class="text-end">RD$ @p.Precio.ToString("N2")</td>
                    <td class="text-center">
                        <form asp-action="CambiarDisponibilidad" asp-route-id="@p.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="disponible" value="@(!p.EstaDisponible)" />
                            <button type="submit" class="btn btn-sm @(p.EstaDisponible ? "btn-success" : "btn-outline-secondary")"
                                    title="@(p.EstaDisponible ? "Marcar no disponible" : "Marcar disponible")">
                                <i class="bi @(p.EstaDisponible ? "bi-check-circle" : "bi-x-circle")"></i>
                            </button>
                        </form>
                    </td>
                    <td class="text-center">
                        @if (p.EsCombo)
                        {
                            <i class="bi bi-check-circle-fill text-warning"></i>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Editar" asp-route-id="@p.Id"
                           class="btn btn-outline-secondary btn-sm me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Eliminar" asp-route-id="@p.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('¿Eliminar este producto?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
