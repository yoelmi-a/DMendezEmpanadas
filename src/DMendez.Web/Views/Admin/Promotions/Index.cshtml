@model IEnumerable<Promocion>
@{
    ViewData["Title"] = "Gestión de Promociones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-tag me-2"></i>Promociones</h2>
    <a asp-action="Crear" class="btn btn-danger">
        <i class="bi bi-plus-lg me-1"></i>Nueva promoción
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nombre</th>
                <th>Código</th>
                <th>Tipo</th>
                <th class="text-end">Valor</th>
                <th>Vigencia</th>
                <th class="text-center">Activa</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr class="@(!p.EstaActiva ? "text-muted" : "")">
                    <td>@p.Nombre</td>
                    <td><code>@p.Codigo</code></td>
                    <td>@(p.TipoDescuento == TipoDescuento.Porcentaje ? "%" : "Monto fijo")</td>
                    <td class="text-end">
                        @(p.TipoDescuento == TipoDescuento.Porcentaje
                            ? $"{p.ValorDescuento:N0}%"
                            : $"RD$ {p.ValorDescuento:N2}")
                    </td>
                    <td>
                        <small>@p.FechaInicio.ToString("dd/MM/yy") — @p.FechaFin.ToString("dd/MM/yy")</small>
                    </td>
                    <td class="text-center">
                        <form asp-action="CambiarEstado" asp-route-id="@p.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="activa" value="@(!p.EstaActiva)" />
                            <button type="submit"
                                    class="btn btn-sm @(p.EstaActiva ? "btn-success" : "btn-outline-secondary")">
                                <i class="bi @(p.EstaActiva ? "bi-check-circle" : "bi-x-circle")"></i>
                            </button>
                        </form>
                    </td>
                    <td>
                        <a asp-action="Editar" asp-route-id="@p.Id"
                           class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
