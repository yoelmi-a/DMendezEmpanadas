@model DetallePedidoViewModel
@{
    ViewData["Title"] = $"Pedido #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-receipt me-2"></i>Pedido #@Model.Id</h2>
    <span class="badge fs-6 @BadgePorEstado(Model.Estado)">@Model.Estado</span>
</div>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-semibold">Productos</div>
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">P. Unit.</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.NombreProducto</td>
                                <td class="text-center">@item.Cantidad</td>
                                <td class="text-end">RD$ @item.PrecioUnitario.ToString("N2")</td>
                                <td class="text-end fw-bold">RD$ @item.Subtotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between text-muted small mb-1">
                    <span>Subtotal</span><span>RD$ @Model.Subtotal.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between text-muted small mb-1">
                    <span>ITBIS</span><span>RD$ @Model.Impuestos.ToString("N2")</span>
                </div>
                @if (Model.Descuento > 0)
                {
                    <div class="d-flex justify-content-between text-success small mb-1">
                        <span>Descuento (@Model.CodigoPromocion)</span>
                        <span>- RD$ @Model.Descuento.ToString("N2")</span>
                    </div>
                }
                <hr class="my-2" />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span class="text-danger">RD$ @Model.Total.ToString("N2")</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <p class="mb-1">
                    <strong>Entrega:</strong>
                    @(Model.MetodoEntrega == MetodoEntrega.Recogida ? "Recogida" : "Domicilio")
                </p>
                <p class="mb-1">
                    <strong>Fecha:</strong>
                    @Model.CreadoEn.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </p>
                @if (!string.IsNullOrEmpty(Model.ReferenciaPago))
                {
                    <p class="mb-0">
                        <strong>Ref. pago:</strong> <code class="small">@Model.ReferenciaPago</code>
                    </p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Historial de estados</div>
            <ul class="list-group list-group-flush">
                @foreach (var h in Model.Historial)
                {
                    <li class="list-group-item">
                        <span class="badge @BadgePorEstado(h.Estado) me-2">@h.Estado</span>
                        <small class="text-muted">@h.FechaHora.ToLocalTime().ToString("dd/MM HH:mm")</small>
                    </li>
                }
            </ul>
        </div>

        @if (Model.SiguienteEstado != null)
        {
            <form asp-action="AvanzarEstado" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger w-100">
                    <i class="bi bi-arrow-right-circle me-1"></i>
                    Avanzar a "@Model.SiguienteEstado"
                </button>
            </form>
        }
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver a pedidos
    </a>
</div>

@functions {
    string BadgePorEstado(string estado) => estado switch
    {
        "Recibido"      => "bg-primary",
        "EnPreparacion" => "bg-warning text-dark",
        "EnCamino"      => "bg-info text-dark",
        "Entregado"     => "bg-success",
        "Cancelado"     => "bg-secondary",
        _               => "bg-light text-dark"
    };
}
