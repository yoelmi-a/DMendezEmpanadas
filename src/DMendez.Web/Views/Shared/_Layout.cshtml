<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")D' Méndez Empanadas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-danger">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-controller="Catalogo" asp-action="Index">
            <i class="bi bi-egg-fried me-1"></i>D' Méndez Empanadas
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Catalogo" asp-action="Index">Menú</a>
                </li>
                @if (User.Identity?.IsAuthenticated == true && !User.IsInRole(SemillaAdminPorDefecto.NombreRolAdministrador))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Carrito" asp-action="Index">
                            <i class="bi bi-cart3"></i> Carrito
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Pedido" asp-action="Historial">Mis Pedidos</a>
                    </li>
                }
                @if (User.IsInRole(SemillaAdminPorDefecto.NombreRolAdministrador))
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-speedometer2"></i> Administración
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="ProductosAdmin" asp-action="Index">Productos</a></li>
                            <li><a class="dropdown-item" asp-controller="PedidosAdmin" asp-action="Index">Pedidos</a></li>
                            <li><a class="dropdown-item" asp-controller="PromocionesAdmin" asp-action="Index">Promociones</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" asp-controller="ReportesAdmin" asp-action="Index">Reportes</a></li>
                        </ul>
                    </li>
                }
            </ul>
            <ul class="navbar-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <span class="nav-link text-white-50">
                            <i class="bi bi-person-circle"></i> @User.Identity.Name
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Cuenta" asp-action="Cerrar" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light btn-sm ms-2 my-1">
                                <i class="bi bi-box-arrow-right"></i> Cerrar sesión
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Cuenta" asp-action="Iniciar">Iniciar sesión</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-light btn-sm ms-2 my-1" asp-controller="Cuenta" asp-action="Registrar">Registrarse</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="container my-4">
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</main>

<footer class="bg-dark text-white-50 text-center py-3 mt-4">
    <small>&copy; @DateTime.Now.Year D' Méndez Empanadas — Sistema educativo</small>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
