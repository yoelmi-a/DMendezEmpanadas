@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-octagon text-danger" style="font-size:4rem;"></i>
    <h2 class="mt-3">Ocurrió un error inesperado</h2>
    <p class="text-muted">Lo sentimos, hubo un problema al procesar tu solicitud.</p>
    <a asp-controller="Catalogo" asp-action="Index" class="btn btn-danger">
        <i class="bi bi-house me-1"></i>Volver al inicio
    </a>
</div>
